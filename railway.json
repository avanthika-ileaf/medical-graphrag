# Railway Configuration for FastAPI Backend

services:
  - name: medknow-backend
    type: web
    source_dir: .
    build_command: pip install -r requirements.txt
    start_command: uvicorn api.main:app --host 0.0.0.0 --port $PORT
    env:
      - NEO4J_URI
      - NEO4J_USER
      - NEO4J_PASSWORD
      - QDRANT_API_KEY
      - LITELLM_MODEL
      - REGOLO_API_KEY
      - LITELLM_API_BASE
